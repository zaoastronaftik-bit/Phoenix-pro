        public void onReceivedSslError(WebView v, android.webkit.SslErrorHandler h, android.net.http.SslError e) {
            try {
                // Для безопасности - отменяем SSL ошибки
                // Но показываем пользователю информацию
                h.cancel();
                toast(Strings.sslError);
            } catch (Exception ex) {}
        }
        
